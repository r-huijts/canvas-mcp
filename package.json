{
  "name": "@r-huijts/canvas-mcp",
  "version": "1.2.0",
  "description": "MCP server for Canvas LMS — courses, assignments, grading, pages, rubrics, and more",
  "author": "R.Huijts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/r-huijts/canvas-mcp"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "canvas-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"try{require('fs').chmodSync('dist/index.js','755')}catch(_){}\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "pack-extension": "npm run build && npx @anthropic-ai/dxt pack",
    "build-extension": "npm run build && npm run pack-extension"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@anthropic-ai/dxt": "^0.1.0",
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
